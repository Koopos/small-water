+import json, sqlite3, datetime
+from pathlib import Path
+
+task_id='task-KFXPcOlQ'
+tasks_path=Path('/Users/koopos/AIGC/agents/github-task-agent/repos/Koopos__task-list/.agent/tasks.json')
+story_path='/Users/koopos/AIGC/stories/github-file-agent/task-KFXPcOlQ.md'
+image_dir=Path('/Users/koopos/AIGC/images/github-file-agent/task-KFXPcOlQ')
+image_paths=[str(image_dir / f'codex-page-{i}.png') for i in range(1,7)]
+preview_urls=[f'/generated/task-KFXPcOlQ/codex-page-{i}.png' for i in range(1,7)]
+pages={
+ 'page_1':'成年人不联系',
+ 'page_2':'最累的不是没人回你。\n\n是你明明感觉到对方在变淡，\n却还要假装自己没那么在意。',
+ 'page_3':'成年人不联系，很多时候不是忙。\n\n是真的没有那么想靠近。\n\n一个人如果想见你、想回你，\n他会在缝隙里找时间。',
+ 'page_4':'其实感情里最伤人的，\n不是一句拒绝。\n\n是那种忽冷忽热，\n让你一边期待，\n一边怀疑自己是不是太认真。',
+ 'page_5':'说白了，舒服的关系不会让你反复猜。\n\n你不用研究语气，\n不用计算谁先主动，\n更不用把每次沉默都解释成“他可能很忙”。',
+ 'page_6':'真正想靠近你的人，\n不会让你一直站在原地等。'
+}
+comment_hook='成年人超过三天不主动联系，其实答案已经很明显了。你同意吗？'
+summary='已生成“成年人不联系”相亲/情感图文 6 页文案，并生成 6 张 1080x1440 Codex 设计图文卡片。'
+artifacts=[story_path, *image_paths, *preview_urls]
+now=datetime.datetime.utcnow().replace(microsecond=0).isoformat()+'Z'
+
+data=json.loads(tasks_path.read_text())
+found=False
+for task in data.get('tasks',[]):
+    if task.get('id')==task_id:
+        if task.get('status')!='running':
+            raise SystemExit(f'target task status is {task.get("status")}, expected running')
+        task['status']='completed'
+        task['completed_at']=now
+        task['updated_at']=now
+        task['error']=None
+        task['output']={
+            'branch': None,
+            'pr_url': None,
+            'artifacts': artifacts,
+            'image_artifacts': image_paths,
+            'preview_urls': preview_urls,
+            'pages': pages,
+            'comment_hook': comment_hook,
+            'summary': summary,
+            'image_style': 'codex-xhs-restrained'
+        }
+        found=True
+        break
+if not found:
+    raise SystemExit('target task not found')
+tasks_path.write_text(json.dumps(data,ensure_ascii=False,indent=2)+'\n')
+
+# keep dashboard in sync
+DB='/Users/koopos/AIGC/agents/agent-task-dashboard/dev.db'
+con=sqlite3.connect(DB)
+output={'branch':None,'pr_url':None,'artifacts':artifacts,'image_artifacts':image_paths,'preview_urls':preview_urls,'pages':pages,'comment_hook':comment_hook,'summary':summary,'image_style':'codex-xhs-restrained'}
+con.execute('update Task set status=?, outputJson=?, artifactsJson=?, completedAt=CURRENT_TIMESTAMP, updatedAt=CURRENT_TIMESTAMP where taskKey=?',('completed', json.dumps(output,ensure_ascii=False,indent=2), json.dumps(artifacts,ensure_ascii=False,indent=2), task_id))
+con.commit()
+print(json.dumps({'status':'completed','artifacts':artifacts},ensure_ascii=False,indent=2))

