generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Project {
  id                  String   @id @default(cuid())
  name                String
  owner               String
  repo                String
  defaultBranch       String   @default("main")
  taskFilePath        String   @default(".agent/tasks.json")
  localPath           String?
  enabled             Boolean  @default(true)
  pollIntervalMinutes Int      @default(15)
  lastSyncedAt        DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tasks    Task[]
  runLogs  RunLog[]

  @@unique([owner, repo])
}

model Task {
  id                 String   @id @default(cuid())
  projectId          String
  taskKey            String
  type               String
  status             String   @default("pending")
  priority           String   @default("normal")
  title              String
  description        String
  acceptanceCriteria String   @default("[]")
  inputJson          String   @default("{}")
  outputJson         String   @default("{}")
  error              String?
  branch             String?
  prUrl              String?
  artifactsJson      String   @default("[]")
  githubCommitSha    String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  startedAt          DateTime?
  completedAt        DateTime?
  lockedBy           String?
  lockedAt           DateTime?

  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  artifacts Artifact[]
  runLogs   RunLog[]

  @@unique([projectId, taskKey])
  @@index([projectId, status])
}

model Artifact {
  id           String   @id @default(cuid())
  taskId       String
  type         String
  path         String?
  url          String?
  prompt       String?
  metadataJson String   @default("{}")
  createdAt    DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model RunLog {
  id          String    @id @default(cuid())
  projectId   String?
  taskId      String?
  runId       String
  status      String
  stdout      String?
  stderr      String?
  startedAt   DateTime  @default(now())
  completedAt DateTime?

  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  task    Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)
}
